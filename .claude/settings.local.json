{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "Bash(npm view:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx next build:*)",
      "Bash(timeout 15 npx next dev:*)"
    ]
  }
}
